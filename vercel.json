{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/templates/index.html"
    },
    {
      "source": "/static/:path*",
      "destination": "/static/:path*"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{.venv/**,__pycache__/**,**/*.pyc}"
    }
  }
}
